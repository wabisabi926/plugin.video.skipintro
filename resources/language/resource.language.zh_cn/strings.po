#: default.py
msgctxt "#32013"
msgid "Outro record deleted"
msgstr "已删除片尾记录"

#: default.py
msgctxt "#32014"
msgid "No outro record"
msgstr "当前无片尾记录"

#: default.py
msgctxt "#32015"
