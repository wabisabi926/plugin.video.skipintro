#: service.py
msgctxt "#32000"
msgid "Auto skip intro - Jumped to %d seconds"
msgstr "自动跳过片头 已跳转至 %d 秒"

#: service.py
msgctxt "#32001"
msgid "Playing next episode..."
msgstr "即将播放下一集..."

#: service.py
msgctxt "#32002"
msgid "Play next episode cancelled"
msgstr "即将播放下一集 已取消"

#: service.py
msgctxt "#32003"
msgid "Playing next episode... Press \"Back\" within %d seconds to cancel"
msgstr "即将播放下一集... %d 秒内按\"返回键\"可取消"

#: default.py
msgctxt "#32004"
msgid "Skip not available for non-episodes"
msgstr "跳过不适用于非剧集"

#: default.py
msgctxt "#32005"
msgid "Intro recorded: %02d:%02d"
msgstr "已记录片头: %02d:%02d"

#: default.py
msgctxt "#32006"
msgid "Outro duration recorded: %02d:%02d"
msgstr "已记录片尾时长: %02d:%02d"

#: default.py
msgctxt "#32007"
